{
  "openapi": "3.0.3",
  "info": {
    "title": "NHL API Documentation",
    "description": "This API provides access to various publicly available statistics and information from the NHL, aimed at making complex data easily digestible for developers and stats enthusiasts. The documentation includes details about different endpoints, usage examples, and guidelines for contributions.",
    "version": "1.0.0",
    "contact": {
      "name": "Drew Hynes",
      "url": "https://gitlab.com/dword4/nhlapi"
    },
    "license": {
      "name": "MIT License",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "https://statsapi.web.nhl.com/api/v1",
      "description": "NHL Stats API"
    },
    {
      "url": "https://records.nhl.com/site/api",
      "description": "NHL Records API"
    }
  ],
  "paths": {
    "/teams": {
      "get": {
        "summary": "Get all teams",
        "description": "Returns a list of all NHL teams",
        "operationId": "getTeams",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "expand",
            "in": "query",
            "description": "Expand modifiers for additional data",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "team.roster",
                "team.schedule.next",
                "team.schedule.previous",
                "team.stats"
              ]
            }
          },
          {
            "name": "season",
            "in": "query",
            "description": "Season in YYYYYYYY format (e.g., 20192020)",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TeamsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/teams/{id}": {
      "get": {
        "summary": "Get team by ID",
        "description": "Returns details for a specific NHL team",
        "operationId": "getTeamById",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Team ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "expand",
            "in": "query",
            "description": "Expand modifiers for additional data",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TeamResponse"
                }
              }
            }
          }
        }
      }
    },
