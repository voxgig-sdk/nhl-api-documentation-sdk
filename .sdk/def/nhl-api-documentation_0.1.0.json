    "/people/{id}/stats": {
      "get": {
        "summary": "Get player statistics",
        "description": "Returns statistics for a specific NHL player",
        "operationId": "getPlayerStats",
        "tags": [
          "Players"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Player ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "stats",
            "in": "query",
            "description": "Type of stats to retrieve",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "statsSingleSeason",
                "yearByYear",
                "careerRegularSeason",
                "homeAndAway"
              ]
            }
          },
          {
            "name": "season",
            "in": "query",
            "description": "Season in YYYYYYYY format",
            "required": false,
            "schema": {
              "type": "string"
            }
